@model SimpleBookingSystem.ViewModels.Admin.PagedResult<SimpleBookingSystem.ViewModels.Admin.AdminUserViewModel>
@{
    ViewData["Title"] = "Manage Users";
}

<div class="container my-4">
    <h3 class="fw-bold mb-4">Manage Users</h3>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Result count -->
    <p class="text-muted small mb-3">
        Showing <strong>@Model.Items.Count</strong> of <strong>@Model.TotalCount</strong> users
        (Page @Model.CurrentPage of @Model.TotalPages)
    </p>

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Bookings</th>
                    <th>Status</th>
                    <th>Joined</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var u in Model.Items)
                {
                    <tr>
                        <td class="fw-semibold">@u.FullName</td>
                        <td>@u.Email</td>
                        <td>
                            <span class="badge @(u.Role == "Admin" ? "bg-danger" : "bg-primary")">
                                @u.Role
                            </span>
                        </td>
                        <td>@u.TotalBookings</td>
                        <td>
                            @if (u.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Inactive</span>
                            }
                        </td>
                        <td>@u.CreatedAt.ToString("dd MMM yyyy")</td>
                        <td>
                            @if (u.Role != "Admin")
                            {
                                @if (u.IsActive)
                                {
                                    <form asp-action="DeactivateUser" method="post" class="d-inline"
                                          onsubmit="return confirm('Deactivate this user?')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@u.UserId" />
                                        <button type="submit" class="btn btn-sm btn-outline-warning me-1">Deactivate</button>
                                    </form>
                                }
                                else
                                {
                                    <form asp-action="ReactivateUser" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="userId" value="@u.UserId" />
                                        <button type="submit" class="btn btn-sm btn-outline-success me-1">Reactivate</button>
                                    </form>
                                }

                                <form asp-action="DeleteUser" method="post" class="d-inline"
                                      onsubmit="return confirm('Permanently remove this user?')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@u.UserId" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                                </form>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <!-- Pagination Controls -->
    @if (Model.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination justify-content-center">

                <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="ManageUsers"
                       asp-route-page="@(Model.CurrentPage - 1)">
                        &laquo; Previous
                    </a>
                </li>

                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="ManageUsers"
                           asp-route-page="@i">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                    <a class="page-link"
                       asp-action="ManageUsers"
                       asp-route-page="@(Model.CurrentPage + 1)">
                        Next &raquo;
                    </a>
                </li>

            </ul>
        </nav>
    }
</div>