@model List<SimpleBookingSystem.ViewModels.Admin.AdminResourceViewModel>
@{
    ViewData["Title"] = "Manage Resources";
}

<div class="container my-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold mb-0">Manage Resources</h3>
        <a asp-action="CreateResource" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Add Resource
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="table-responsive">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Location</th>
                    <th>Bookings</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>
                            <div class="fw-semibold">@r.Name</div>
                            <div class="text-muted small">@r.Description</div>
                        </td>
                        <td>@r.TypeName</td>
                        <td>@(r.Location ?? "—")</td>
                        <td>@r.TotalBookings</td>
                        <td>
                            @if (r.IsActive)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Inactive</span>
                            }
                        </td>
                        <td>
                            <a asp-action="EditResource"
                               asp-route-resourceId="@r.ResourceId"
                               class="btn btn-sm btn-outline-primary me-1">Edit</a>

                            <form asp-action="ToggleResource" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="resourceId" value="@r.ResourceId" />
                                <button type="submit" class="btn btn-sm btn-outline-warning me-1">
                                    @(r.IsActive ? "Deactivate" : "Activate")
                                </button>
                            </form>

                            <form asp-action="DeleteResource" method="post" class="d-inline"
                                  onsubmit="return confirm('Remove this resource?')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="resourceId" value="@r.ResourceId" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">Remove</button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>