@model SimpleBookingSystem.ViewModels.Booking.EditBookingViewModel
@{
    ViewData["Title"] = "Edit Booking";
}

<div class="container my-4">

    <!-- Resource Info -->
    <div class="card border-0 bg-primary-subtle mb-4">
        <div class="card-body">
            <span class="badge bg-primary mb-1">@Model.TypeName</span>
            <h4 class="fw-bold mb-1">@Model.ResourceName</h4>
            @if (!string.IsNullOrWhiteSpace(Model.Location))
            {
                <p class="mb-0 small text-muted">
                    <i class="bi bi-geo-alt me-1"></i>@Model.Location
                </p>
            }
        </div>
    </div>

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <form asp-action="Edit" asp-controller="Booking" method="post" id="bookingForm">
        @Html.AntiForgeryToken()
        <input type="hidden" name="BookingId" value="@Model.BookingId" />
        <input type="hidden" name="ResourceId" value="@Model.ResourceId" />
        <input type="hidden" name="ResourceName" value="@Model.ResourceName" />
        <input type="hidden" name="TypeName" value="@Model.TypeName" />
        <input type="hidden" name="Location" value="@Model.Location" />
        <input type="hidden" name="StartTime" id="startTimeHidden" />
        <input type="hidden" name="EndTime" id="endTimeHidden" />

        <div class="row g-4">

            <!-- Left: Calendar -->
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-transparent fw-semibold">
                        <i class="bi bi-calendar3 me-2"></i>Select a New Time Slot
                        <span class="text-muted small fw-normal ms-2">
                            Click an available slot to select it
                        </span>
                    </div>
                    <div class="card-body p-3">
                        <div id="calendar"></div>
                    </div>
                </div>

                <!-- Legend -->
                <div class="d-flex gap-3 mt-2 ms-1">
                    <span class="small"><span class="badge bg-danger me-1">&nbsp;</span> Booked</span>
                    <span class="small"><span class="badge bg-warning me-1">&nbsp;</span> Current Booking</span>
                    <span class="small"><span class="badge bg-success me-1">&nbsp;</span> New Selection</span>
                    <span class="small"><span class="badge bg-light border me-1 text-dark">&nbsp;</span> Available</span>
                </div>
            </div>

            <!-- Right: Booking Summary -->
            <div class="col-lg-4">
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-transparent fw-semibold">
                        <i class="bi bi-info-circle me-2"></i>Booking Summary
                    </div>
                    <div class="card-body d-flex flex-column">

                        <!-- Current booking info -->
                        <div class="mb-3 p-2 bg-warning-subtle rounded">
                            <div class="text-muted small mb-1">Current Booking</div>
                            <div class="fw-semibold small">
                                @Model.StartTime.ToString("dd MMM yyyy")
                            </div>
                            <div class="small">
                                @Model.StartTime.ToString("hh:mm tt") — @Model.EndTime.ToString("hh:mm tt")
                            </div>
                        </div>

                        <div id="noSelection" class="text-center text-muted py-3">
                            <i class="bi bi-hand-index fs-2 mb-2 d-block"></i>
                            Click a slot to choose a new time
                        </div>

                        <div id="selectionInfo" class="d-none">
                            <div class="text-muted small fw-semibold mb-2">New Selection</div>
                            <div class="mb-2">
                                <div class="text-muted small mb-1">Date</div>
                                <div class="fw-semibold" id="selectedDate">—</div>
                            </div>
                            <div class="mb-2">
                                <div class="text-muted small mb-1">Start Time</div>
                                <div class="fw-semibold" id="selectedStart">—</div>
                            </div>
                            <div class="mb-2">
                                <div class="text-muted small mb-1">End Time</div>
                                <div class="fw-semibold" id="selectedEnd">—</div>
                            </div>
                            <div class="mb-3">
                                <div class="text-muted small mb-1">Duration</div>
                                <div class="fw-semibold" id="selectedDuration">—</div>
                            </div>
                            <hr />
                            <div class="mb-2">
                                <div class="text-muted small mb-1">Resource</div>
                                <div class="fw-semibold">@Model.ResourceName</div>
                            </div>
                            @if (!string.IsNullOrWhiteSpace(Model.Location))
                            {
                                <div class="mb-2">
                                    <div class="text-muted small mb-1">Location</div>
                                    <div class="fw-semibold">@Model.Location</div>
                                </div>
                            }
                        </div>

                        <div class="mt-3 d-grid gap-2">
                            <button type="submit" id="confirmBtn" class="btn btn-primary" disabled>
                                Update Booking
                            </button>
                            <a asp-controller="Booking" asp-action="MyBookings"
                               class="btn btn-outline-secondary">
                                Back to My Bookings
                            </a>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>

    <script>
        const resourceId    = "@Model.ResourceId";
        const bookingId     = "@Model.BookingId";
        const startHidden   = document.getElementById("startTimeHidden");
        const endHidden     = document.getElementById("endTimeHidden");
        const confirmBtn    = document.getElementById("confirmBtn");
        const noSelection   = document.getElementById("noSelection");
        const selectionInfo = document.getElementById("selectionInfo");

        // Current booking times — used to show yellow block and skip in red events
        const currentStart = new Date("@Model.StartTime.ToString("yyyy-MM-ddTHH:mm:ss")");
        const currentEnd   = new Date("@Model.EndTime.ToString("yyyy-MM-ddTHH:mm:ss")");

        // ⭐ Use FullCalendar's built-in events function — same fix as Create.cshtml
        // Automatically re-fetches when user navigates to a new week/day
        function loadEvents(fetchInfo, successCallback, failureCallback) {
            const start = fetchInfo.startStr.split("T")[0];
            const end   = fetchInfo.endStr.split("T")[0];

            fetch(`/Booking/GetBookedSlots?resourceId=${resourceId}&startDate=${start}&endDate=${end}&_t=${Date.now()}`, {
                cache: "no-store"
            })
            .then(res => {
                if (!res.ok) throw new Error("Network error");
                return res.json();
            })
            .then(data => {
                const events = [];

                // ⭐ Always add current booking as yellow — shown regardless of week
                events.push({
                    id:        "currentBooking",
                    title:     "Current Booking",
                    start:     currentStart,
                    end:       currentEnd,
                    color:     "#ffc107",
                    textColor: "#000"
                });

                // Add all other booked slots as red — skip current booking
                data.forEach(slot => {
                    const slotStart = new Date(slot.start);

                    // Skip current booking — already shown in yellow above
                    if (slotStart.getTime() === currentStart.getTime()) return;

                    events.push({
                        title:     "Booked",
                        start:     slot.start,
                        end:       slot.end,
                        color:     "#dc3545",
                        textColor: "#fff"
                    });
                });

                successCallback(events);
            })
            .catch(err => {
                console.error("Failed to load booked slots:", err);
                failureCallback(err);
            });
        }

        const calendar = new FullCalendar.Calendar(document.getElementById("calendar"), {
            initialView:  "timeGridWeek",
            allDaySlot:   false,
            slotMinTime:  "08:00:00",
            slotMaxTime:  "20:00:00",
            slotDuration: "01:00:00",
            snapDuration: "01:00:00",
            initialDate:  currentStart,  // open on current booking's week
            headerToolbar: {
                left:   "prev,next today",
                center: "title",
                right:  "timeGridWeek,timeGridDay"
            },

            // ⭐ Pass function — FullCalendar manages fetching automatically
            events: loadEvents,

            select: function (info) {
                const start    = info.start;
                const end      = info.end;
                const duration = (end - start) / 3600000;

                // Remove previous new selection only — keep yellow + red events
                const prev = calendar.getEventById("selection");
                if (prev) prev.remove();

                // Add green new selection block
                calendar.addEvent({
                    id:        "selection",
                    title:     "New Booking",
                    start:     start,
                    end:       end,
                    color:     "#198754",
                    textColor: "#fff"
                });

                startHidden.value = formatForCSharp(start);
                endHidden.value   = formatForCSharp(end);

                noSelection.classList.add("d-none");
                selectionInfo.classList.remove("d-none");

                document.getElementById("selectedDate").textContent =
                    start.toLocaleDateString("en-MY", { weekday: "long", year: "numeric", month: "long", day: "numeric" });
                document.getElementById("selectedStart").textContent =
                    start.toLocaleTimeString("en-MY", { hour: "2-digit", minute: "2-digit" });
                document.getElementById("selectedEnd").textContent =
                    end.toLocaleTimeString("en-MY", { hour: "2-digit", minute: "2-digit" });
                document.getElementById("selectedDuration").textContent =
                    duration === 1 ? "1 hour" : `${duration} hours`;

                confirmBtn.disabled = false;
            },

            selectable:    true,
            selectMirror:  true,
            height:        "auto"
        });

        calendar.render();

        function formatForCSharp(date) {
            const pad = n => String(n).padStart(2, "0");
            return `${date.getFullYear()}-${pad(date.getMonth() + 1)}-${pad(date.getDate())}T${pad(date.getHours())}:${pad(date.getMinutes())}:00`;
        }
    </script>
}